# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Intelligent Document AI Platform
APP_VERSION=2.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, zero-ops, file-based)
DATABASE_URL=sqlite+aiosqlite:///./data/documents.db

# Postgres (production upgrade — just swap this line)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/docai

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini

# ── Vector Store ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_COLLECTION=documents
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RAG_TOP_K=5

# ── Cache ─────────────────────────────────────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
